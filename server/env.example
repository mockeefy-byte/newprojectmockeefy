# ===========================================
# Mockeefy – Server environment variables
# ===========================================
# 1. Copy this file to .env in the same folder (server/.env)
# 2. Replace placeholder values with your real keys
# 3. Never commit .env to git (it should be in .gitignore)
# ===========================================

# ----- Server -----
PORT=5000
NODE_ENV=development

# ----- Frontend (CORS, redirects, Socket.IO) -----
CLIENT_URL=http://localhost:5173
# FRONTEND_URL=https://your-frontend.onrender.com

# ----- Database -----
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/mockeefy?retryWrites=true&w=majority

# ----- Auth (JWT + Google OAuth) -----
JWT_SECRET=your_jwt_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# ----- Session -----
SESSION_SECRET=your_session_secret

# ----- Payment (Razorpay) -----
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ----- Email (SMTP / Nodemailer) -----
# Gmail: use App Password; or any SMTP host
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_app_password
# EMAIL_FROM=noreply@yourdomain.com

# ----- Storage (Cloudinary for uploads) -----
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...
# Optional: set to "local" to skip Cloudinary
# STORAGE_TYPE=local

# ----- TURN (Coturn for WebRTC – mobile/different network) -----
# Only needed if you host Coturn for video calls
# TURN_HOST=turn.yourdomain.com
# TURN_PORT=3478
# TURN_USERNAME=your_turn_user
# TURN_CREDENTIAL=your_turn_secret

# ===========================================
# Any API keys – add here and use in code as process.env.KEY_NAME
# ===========================================
# Example: OpenAI for Interview Tips auto-generation
# OPENAI_API_KEY=sk-...

# Add any other API keys you need, for example:
# STRIPE_SECRET_KEY=sk_...
# SENDGRID_API_KEY=SG....
# TWILIO_AUTH_TOKEN=...
